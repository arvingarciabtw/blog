---
import BaseHead from '../components/base-head.astro';
import Footer from '../components/footer.astro';
import Divider from "../components/divider.astro";

const { title, description, pubDate, } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
      .wrapper {
        border-left: 1px solid var(--color-gray-200);
        border-right: 1px solid var(--color-gray-200);
      }
      article {
        .top {
          padding: var(--space-3xl);
          display: flex;
          flex-direction: column;
          gap: var(--space-md);
        }

        .back {
          text-decoration: none;
          color: var(--color-fg);
          font-family: "departure-mono", monospace;
          font-size: var(--font-md);
        }

        .title {
          font-family: "offbit-trial-101", sans-serif;
          font-size: var(--font-3xl);
          font-weight: var(--weight-regular);
          line-height: 1.25;
        }

        .date {
          margin-top: var(--space-2xl);
          font-family: "departure-mono", monospace;
          font-size: var(--font-sm);
        }

        .middle {
          display: grid;
          grid-template-columns: 1fr 300px;
        }

        .sidebar {
          position: sticky;
          top: 0;
          align-self: start;
          padding: var(--space-3xl);
          display: flex;
          flex-direction: column;
          gap: var(--space-md);

          p {
            font-family: "departure-mono", monospace;
            font-size: var(--font-sm);
            text-transform: uppercase;
          }
        }

        .prose {
          padding: var(--space-3xl);
          display: flex;
          flex-direction: column;
          gap: var(--space-xl);
          color: var(--color-fg);
          font-family: "sentient", serif;
          font-size: var(--font-sm);
          font-weight: var(--weight-regular);
          border-right: 1px solid var(--color-gray-200);
          min-width: 100%;
        }
      }

      :global(.prose p) {
        line-height: 2;
      }
      :global(.prose a) {
        color: var(--color-primary);
      }
      :global(.prose a):hover {
        text-decoration: none;
      }
      :global(.prose h2) {
        font-size: var(--font-xl);
      }
      :global(.prose blockquote) {
        color: var(--color-gray-700);
        padding-left: var(--space-md);
        border-left: 4px solid var(--color-gray-500);
        font-style: italic;
      }
      :global(.prose code) {
        padding: 1px 6px;
        font-family: "commit-mono", monospace;
        font-size: var(--font-xs);
        background: var(--color-fg);
        color: var(--color-bg);
        border-radius: 6px;
      }
      :global(.prose pre) {
        padding: var(--space-md);
        font-family: "commit-mono", monospace;
        font-size: var(--font-xs);
        border-radius: 6px;
        background-color: var(--color-gray-100) !important;
      }
      html.dark :global(.prose pre) {
        background-color: var(--color-gray-100) !important;
      }
      :global(.prose pre > code) {
        padding: 0;
      }
      html.dark :global(.prose pre > code > * > *) {
        background-color: var(--color-gray-100) !important;
      }

      @media (max-width: 700px) {
        .wrapper {
          .middle {
            grid-template-columns: 1fr;

            .prose {
              border: none;
            }

            .sidebar {
              display: none;
            }
          }
        }
      }

      @media (max-width: 500px) {
        article {
          .top, .prose {
            padding: var(--space-lg);
          }
        }
      }
		</style>
	</head>
	<body>
    <div class="wrapper">
      <main>
        <article>
          <div class="top">
            <a href="/" class="back">&lt;&lt;</a>
            <h1 class="title">{title}</h1>
            <p class="date">{pubDate.toString().slice(4, 10).toUpperCase()}</p>
          </div>
          <Divider />
          <div class="middle">
            <div class="prose">
              <slot />
            </div>
            <aside class="sidebar">
              <p>STATIC HEADING 1</p>
              <p>STATIC HEADING 2</p>
              <p>STATIC HEADING 3</p>
              <p>STATIC HEADING 4</p>
              <p>STATIC HEADING 5</p>
            </aside>
          </div>
        </article>
      </main>
      <Divider />
      <Footer />
    </div>
	</body>
</html>
